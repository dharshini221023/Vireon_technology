# ─── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# ─── JWT (for Auth) ──────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production
JWT_EXPIRES_IN=7d

# ─── Database (MongoDB) ───────────────────────────────────────
# Local MongoDB (make sure `mongod` / MongoDB Compass / MongoDB service is running):
MONGODB_URI=mongodb://127.0.0.1:27017/vireon_technologies
# Or, MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/vireon_technologies?retryWrites=true&w=majority
